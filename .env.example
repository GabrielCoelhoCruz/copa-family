# Supabase (obrigatório para app e E2E)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-or-publishable-key

# Supabase service role — somente servidor (server actions, RLS restritiva e sync)
SUPABASE_SERVICE_ROLE_KEY=

# API-Football / API-Sports — somente servidor (sync opcional via provider api-football)
API_FOOTBALL_KEY=

# TheSportsDB — somente servidor (sync padrão Copa 2026; use `3` só em dev)
THESPORTSDB_API_KEY=

# RapidAPI WC26 Live Football — 104 jogos Copa 2026 (recomendado para catálogo completo)
RAPIDAPI_WC26_KEY=

# Provider padrão: wc26-rapidapi | thesportsdb | api-football
FIXTURE_SYNC_PROVIDER=wc26-rapidapi

# Temporada gravada no Supabase
WORLD_CUP_SEASON=2026

# API-Football: temporada de fetch no plano free (2022–2024)
API_FOOTBALL_FETCH_SEASON=2022

# Token para POST /api/admin/fixtures/sync (header Authorization: Bearer <token>)
FIXTURE_SYNC_TOKEN=

# Widgets API-Sports (opcional; expõe a chave no HTML — use restrição de domínio no dashboard)
NEXT_PUBLIC_ENABLE_API_SPORTS_WIDGETS=false
NEXT_PUBLIC_API_SPORTS_WIDGET_KEY=

# Painel de métricas MVP (somente dev/staging)
ENABLE_ADMIN_METRICS=false
